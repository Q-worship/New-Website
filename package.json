{
  "name": "q-worship-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:chat-api": "wrangler dev --config workers/whatsapp-chat/wrangler.toml --port 8787",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "setup:chat-api": "node scripts/setup-chat-worker.mjs",
    "deploy:chat-api": "node scripts/ensure-chat-kv.mjs && wrangler deploy --config workers/whatsapp-chat/wrangler.toml",
    "deploy:site": "npm run build && wrangler deploy",
    "deploy:production": "npm run deploy:chat-api && wrangler deploy",
    "deploy": "npm run deploy:production",
    "verify:faq-matcher": "node scripts/verify-faq-matcher.mjs",
    "verify:chatbot-greetings": "node scripts/verify-chatbot-greetings.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260630.1",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^6.0.0",
    "wrangler": "^4.104.0"
  }
}
