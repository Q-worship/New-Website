# Website frontend
# Local dev:
VITE_CHAT_API_URL=http://localhost:8787

# Production (set in Cloudflare Pages → Settings → Environment variables, then redeploy):
# VITE_CHAT_API_URL=https://qworship-whatsapp-chat.<your-subdomain>.workers.dev
# See DEPLOY.md for full checklist.

# Legacy Crisp handoff (unused when VITE_CHAT_API_URL is set)
VITE_CRISP_WEBSITE_ID=

# --- Cloudflare Worker secrets (set via wrangler secret put, not in .env) ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=   (can be set in wrangler.toml [vars])
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_AGENT_PHONE=
# AGENT_API_KEY=
