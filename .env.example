# Website frontend
# Local dev (Vite proxies /api to the chat worker on port 8787):
# Leave VITE_CHAT_API_URL unset, or set explicitly:
VITE_CHAT_API_URL=http://localhost:8787

# Production — recommended: same-origin proxy (no CORS)
# 1. Do NOT set VITE_CHAT_API_URL (or leave it empty) so the browser calls /api/chat/* on your site.
# 2. The site Worker proxies to qworship-whatsapp-chat via a Service Binding in wrangler.jsonc
#    (no CHAT_API_ORIGIN env var needed).
#
# Alternative (cross-origin, not recommended): set VITE_CHAT_API_URL to the worker URL at build time.
# See DEPLOY.md for the full checklist.

# Legacy Crisp handoff (unused when chat API is configured)
VITE_CRISP_WEBSITE_ID=

# --- Cloudflare Worker secrets (set via wrangler secret put, not in .env) ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=   (can be set in wrangler.toml [vars])
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_AGENT_PHONE=
# AGENT_API_KEY=
