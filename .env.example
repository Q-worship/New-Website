# Website frontend
# Local dev — leave unset to use same-origin /api (Vite proxies below):
# VITE_CHAT_API_URL=
# VITE_API_URL=

# Optional overrides (cross-origin, not recommended for production):
# VITE_CHAT_API_URL=http://localhost:8787
# VITE_API_URL=http://localhost:5000/api

# Local Vite proxies (vite.config.ts):
#   /api/chat  -> http://localhost:8787  (chat worker) — run: npm run dev:chat-api
#   /api/auth  -> http://localhost:5000  (Qworship v2 API) — run: npm run dev:auth-api

# Qworship v2 auth API (local MongoDB)
# 1. Install: cd Qworship-v2 && pnpm install
# 2. Optional: Qworship-v2/apps/server/.env with MONGODB_URI (default: mongodb://127.0.0.1:27017/qworship-v2)
# 3. Start MongoDB locally, then: npm run dev:auth-api (auth-only v2 server on port 5000)
# OTP codes are logged in the v2 server console: [dev] Verification code for ...
# Emergency in-memory mock (no MongoDB): npm run dev:auth-api:mock

# Production — recommended: same-origin proxy (no CORS)
# 1. Do NOT set VITE_CHAT_API_URL or VITE_API_URL at build time.
# 2. Browser calls /api/chat/* and /api/auth/* on your site domain.
# 3. Site Worker proxies chat via Service Binding (wrangler.jsonc).
# 4. Site Worker proxies auth via AUTH_API_ORIGIN (see DEPLOY.md).
# 5. OTP emails are sent by the v2 API via Resend (RESEND_API_KEY on v2 host — not on this site).
#
# Legacy Crisp handoff (unused when chat API is configured)
VITE_CRISP_WEBSITE_ID=

# Marketing auth — mock signup/login flow without backend (hardcoded ON in authApi.ts).
# When the real auth API is live, set MOCK_AUTH = false in src/lib/authApi.ts and rebuild.
# VITE_MOCK_AUTH is reserved for a future env-driven toggle.

# --- Cloudflare site Worker runtime (Dashboard or wrangler secret put) ---
# AUTH_API_ORIGIN=https://qworship-auth-api.onrender.com
#
# --- v2 API server only (Railway/Render/VPS — see Qworship-v2/apps/server/.env.example) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM=Qworship <verify@qworship.com>
# MONGODB_URI=...
# JWT_SECRET=...
# NODE_ENV=production
#
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_AGENT_PHONE=
# AGENT_API_KEY=
