# Production stack for app.qworship.com — copy to .env on the deploy host (never commit .env)

# === Required (unchanged from previous deploy) ===
MONGODB_URI=
JWT_SECRET=
RESEND_API_KEY=
EMAIL_FROM=Qworship <verify@qworship.com>

# === Marketing + gateway cutover ===
FRONTEND_URL=https://app.qworship.com
VITE_API_URL=/api
VITE_WS_URL=wss://app.qworship.com
CHAT_API_ORIGIN=https://new-website.vianneycm.workers.dev

